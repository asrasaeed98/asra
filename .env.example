# Database
DATABASE_URL=postgresql://findings:findings@localhost:5432/findings

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (server-side only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SUMMARY=claude-haiku-4-5
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6

# data.gov CKAN
DATA_GOV_CKAN_API=https://catalog.data.gov/api/3/action

# Analysis limits
ROW_CAP=100000
MIN_SAMPLE=10000
SAMPLE_PCT=0.05
RANDOM_SEED=42

# API
CORS_ORIGINS=http://localhost:3000
API_PUBLIC_URL=http://localhost:8000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web branding
NEXT_PUBLIC_APP_NAME=OpenFinds
APP_DISPLAY_NAME=OpenFinds

# Catalog sync
ADMIN_SYNC_TOKEN=
CKAN_SYNC_MAX_PACKAGES=40
CKAN_SYNC_ROWS=25
WB_SYNC_MAX_INDICATORS=250

# Local SQLite (switch to Postgres in production)
# DATABASE_URL=sqlite:///./findings_local.db
