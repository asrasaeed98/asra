# Database
DATABASE_URL=postgresql://findings:findings@localhost:5432/findings

# Redis
REDIS_URL=redis://localhost:6379/0

# Anthropic (server-side only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SUMMARY=claude-haiku-4-5
ANTHROPIC_MODEL_CHAT=claude-sonnet-4-6
# Hard ceiling on Anthropic spend per calendar month (USD). <= 0 disables the cap.
AI_MONTHLY_BUDGET_USD=100

# data.gov CKAN
DATA_GOV_CKAN_API=https://catalog.data.gov/api/3/action

# Analysis limits
ROW_CAP=100000
MIN_SAMPLE=10000
SAMPLE_PCT=0.05
RANDOM_SEED=42

# API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
API_PUBLIC_URL=http://localhost:8000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000

# Web branding
NEXT_PUBLIC_APP_NAME=Findings
APP_DISPLAY_NAME=Findings

# Catalog sync
# Local dev: use larger caps (e.g. CKAN_SYNC_MAX_INDEXED=10000). Prod (Railway + GitHub Actions): see docs/findings-ai/CATALOG_AUTOMATION.md
ADMIN_SYNC_TOKEN=
CKAN_SYNC_MAX_PACKAGES=200
CKAN_SYNC_MAX_INDEXED=0
CKAN_SYNC_ROWS=100
CKAN_SYNC_MAX_PAGES=20
WB_SYNC_MAX_INDICATORS=2000
WB_SYNC_MAX_INDEXED=0
WB_SYNC_MAX_PER_FAMILY=2
WB_SYNC_MAX_PER_TOPIC=250

# FRED (St. Louis Fed) — free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
FRED_SYNC_MAX_SERIES=150
FRED_SYNC_MAX_INDEXED=0

CATALOG_SYNC_INTERVAL_HOURS=0
CATALOG_PROBE_INTERVAL_HOURS=0
CATALOG_SYNC_RUN_ON_STARTUP=false
CATALOG_PROBE_BATCH_SIZE=500

# Catalog quality gates
CATALOG_PROBE_ENABLED=true
CATALOG_PROBE_MAX_BYTES=256000
CATALOG_PROBE_TIMEOUT_SEC=20
CATALOG_MIN_ROWS=20
ANALYSIS_MIN_ROWS=20

# Session DuckDB files (local disk)
SESSION_DATA_DIR=./session_data
MAX_DOWNLOAD_BYTES=50000000

# Local SQLite (default: apps/api/findings_local.db)
# DATABASE_URL=sqlite:///./findings_local.db
